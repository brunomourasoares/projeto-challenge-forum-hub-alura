		{
			"name": "Criar Usuário Aleatório",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"function gerarSenhaForte(tamanho = 8) {\r",
							"    const maiusculas = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\r",
							"    const minusculas = \"abcdefghijklmnopqrstuvwxyz\";\r",
							"    const numeros = \"0123456789\";\r",
							"    const simbolos = \"@#$%^&+=\";\r",
							"\r",
							"    let senha = [\r",
							"        maiusculas[Math.floor(Math.random() * maiusculas.length)],\r",
							"        minusculas[Math.floor(Math.random() * minusculas.length)],\r",
							"        numeros[Math.floor(Math.random() * numeros.length)],\r",
							"        simbolos[Math.floor(Math.random() * simbolos.length)]\r",
							"    ];\r",
							"\r",
							"    const todos = maiusculas + minusculas + numeros + simbolos;\r",
							"\r",
							"    for (let i = senha.length; i < tamanho; i++) {\r",
							"        senha.push(todos[Math.floor(Math.random() * todos.length)]);\r",
							"    }\r",
							"\r",
							"    senha = senha.sort(() => Math.random() - 0.5).join('');\r",
							"\r",
							"    return senha;\r",
							"}\r",
							"\r",
							"pm.environment.set(\"senhaAleatoria\", gerarSenhaForte(8));"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.environment.set(\"emailAleatorio\", pm.response.json().email);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
